{
  "name": "soda-web",
  "version": "1.1.1",
  "scripts": {
    "dev": "vite",
    "build:production": "NODE_OPTIONS=--max_old_space_size=1024 vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview --port 5173",
    "test:unit": "vitest --environment jsdom",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "generate": "openapi --input http://localhost/api/openapi.json --output ./src/client --exportSchemas true --useOptions",
    "test": "vitest"
  },
  "dependencies": {
    "@carbon/icons-vue": "^10.49.1",
    "@chenfengyuan/vue-barcode": "^2.0.0",
    "@revolist/revogrid-column-numeral": "^1.0.2",
    "@revolist/vue3-datagrid": "^3.1.0",
    "@vueuse/core": "^9.3.1",
    "ag-grid-community": "^28.2.0",
    "ag-grid-vue3": "^28.2.0",
    "client-oauth2": "^4.3.3",
    "dataclass": "^2.0.0",
    "jose": "^4.8.1",
    "pinia": "^2.0.13",
    "tone": "^14.7.77",
    "vue": "^3.2.41",
    "vue-dataset": "^3.4.8",
    "vue-router": "4.1.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.1.0",
    "@testing-library/vue": "^6.4.2",
    "@vitejs/plugin-vue": "^3.1.2",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.0.0-rc.20",
    "eslint": "^8.5.0",
    "eslint-plugin-vue": "^9.6.0",
    "happy-dom": "^7.5.12",
    "jsdom": "^20.0.1",
    "naive-ui": "^2.29.0",
    "openapi-typescript-codegen": "^0.23.0",
    "unplugin-vue-components": "^0.22.8",
    "vite": "^3.1.8",
    "vitest": "^0.24.3"
  }
}
