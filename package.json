{
  "name": "vue-project",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "test:unit": "vitest --environment jsdom",
    "test:e2e": "start-server-and-test preview http://127.0.0.1:5050/ 'cypress open'",
    "test:e2e:ci": "start-server-and-test preview http://127.0.0.1:5050/ 'cypress run'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "generate": "openapi --input http://localhost/api/openapi.json --output ./src/client --exportSchemas true --useOptions",
    "test": "vitest",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@carbon/icons-vue": "^10.49.1",
    "@chenfengyuan/vue-barcode": "^2.0.0",
    "@revolist/revogrid-column-numeral": "^1.0.2",
    "@revolist/vue3-datagrid": "^3.1.0",
    "@vueuse/core": "^8.6.0",
    "ag-grid-community": "^27.3.0",
    "ag-grid-vue3": "^27.3.0",
    "client-oauth2": "^4.3.3",
    "color": "^4.2.3",
    "dataclass": "^2.0.0",
    "jose": "^4.8.1",
    "pinia": "^2.0.13",
    "vue": "^3.2.33",
    "vue-dataset": "^3.4.8",
    "vue-router": "4.1.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.1.0",
    "@testing-library/vue": "^6.4.2",
    "@types/color": "^3.0.3",
    "@vitejs/plugin-vue": "^2.3.1",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.0.0-rc.20",
    "cypress": "^10.1.0",
    "eslint": "^8.5.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-vue": "^8.2.0",
    "happy-dom": "^4.0.1",
    "jsdom": "^19.0.0",
    "naive-ui": "^2.29.0",
    "openapi-typescript-codegen": "^0.23.0",
    "prettier": "^2.5.1",
    "start-server-and-test": "^1.14.0",
    "unplugin-vue-components": "^0.19.5",
    "vite": "^2.9.5",
    "vitest": "^0.9.4"
  }
}
