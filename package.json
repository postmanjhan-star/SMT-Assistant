{
  "name": "smt-assistant",
  "version": "1.1.4",
  "scripts": {
    "dev": "vite",
    "build:production": "NODE_OPTIONS=--max_old_space_size=2048 vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "generate": "openapi --input http://localhost/api/openapi.json --output ./src/client --exportSchemas true --useOptions",
    "test": "vitest",
    "test:unit": "vitest --environment jsdom",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ag-grid-community": "^29.0.0",
    "ag-grid-vue3": "^29.0.0",
    "tabulator-tables": "^5.4.3",
    "tone": "^14.7.77",
    "v8-to-istanbul": "^9.0.1",
    "vue": "^3.2.41",
    "vue-meta": "^3.0.0-alpha.10",
    "vue-router": "4.1.6"
  },
  "devDependencies": {
    "@babel/types": "^7.21.4",
    "@faker-js/faker": "^7.6.0",
    "@playwright/test": "^1.28.1",
    "@rushstack/eslint-patch": "^1.1.0",
    "@testing-library/vue": "^7.0.0",
    "@types/node": "^18.15.0",
    "@types/tabulator-tables": "^5.4.2",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vitest/browser": "^0.29.8",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.0.0-rc.20",
    "eslint": "^8.36.0",
    "eslint-plugin-vue": "^9.6.0",
    "happy-dom": "^9.1.7",
    "jsdom": "^21.1.1",
    "naive-ui": "^2.29.0",
    "openapi-typescript-codegen": "^0.23.0",
    "playwright": "^1.32.2",
    "unplugin-vue-components": "^0.24.0",
    "vite": "^4.0.0",
    "vitest": "^0.29.2"
  }
}
