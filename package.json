{
  "name": "soda-web",
  "version": "1.1.3",
  "scripts": {
    "dev": "vite",
    "build:production": "NODE_OPTIONS=--max_old_space_size=1024 vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview --port 5173",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "generate": "openapi --input http://localhost/api/openapi.json --output ./src/client --exportSchemas true --useOptions",
    "test": "vitest",
    "test:unit": "vitest --environment jsdom",
    "coverage": "vitest run --coverage"
  },
  "dependenciesComments": {
    "@antfu/utils": "@antfu/utils v0.6.1 has a bug. Skip it."
  },
  "dependencies": {
    "@carbon/icons-vue": "^10.49.1",
    "@chenfengyuan/vue-barcode": "^2.0.0",
    "@revolist/revogrid-column-numeral": "^1.0.2",
    "@revolist/vue3-datagrid": "^3.1.0",
    "@vueuse/core": "^9.3.1",
    "ag-grid-community": "^29.0.0",
    "ag-grid-vue3": "^29.0.0",
    "client-oauth2": "^4.3.3",
    "dataclass": "^2.0.0",
    "ip-num": "^1.5.0",
    "jose": "^4.8.1",
    "pinia": "^2.0.13",
    "plotly.js-dist-min": "^2.18.2",
    "plotly.js-locales": "^2.18.2",
    "tabulator-tables": "^5.4.3",
    "tone": "^14.7.77",
    "v8-to-istanbul": "^9.0.1",
    "vue": "^3.2.41",
    "vue-dataset": "^3.4.8",
    "vue-meta": "^3.0.0-alpha.10",
    "vue-router": "4.1.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.19.1/xlsx-0.19.1.tgz"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@playwright/test": "^1.28.1",
    "@rushstack/eslint-patch": "^1.1.0",
    "@testing-library/vue": "^6.4.2",
    "@types/node": "^18.11.18",
    "@types/plotly.js-dist-min": "^2.3.1",
    "@types/tabulator-tables": "^5.4.2",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.0.0-rc.20",
    "eslint": "^8.5.0",
    "eslint-plugin-vue": "^9.6.0",
    "happy-dom": "^8.1.0",
    "jsdom": "^21.0.0",
    "naive-ui": "^2.29.0",
    "openapi-typescript-codegen": "^0.23.0",
    "unplugin-vue-components": "^0.24.0",
    "vite": "^4.0.0",
    "vitest": "^0.29.2"
  }
}
