{
  "name": "smt-assistant",
  "version": "1.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:production": "NODE_OPTIONS=--max_old_space_size=2048 vite build",
    "build:staging": "NODE_OPTIONS=--max-old-space-size=4096 vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "generate": "openapi --input http://localhost/api/openapi.json --output ./src/client --exportSchemas true --useOptions",
    "test": "vitest",
    "test:unit": "vitest --environment jsdom",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ag-grid-community": "^30.0.2",
    "ag-grid-vue3": "^30.0.2",
    "lucide-vue-next": "^0.545.0",
    "pinia": "^2.3.0",
    "tabulator-tables": "^5.4.3",
    "tone": "^14.7.77",
    "v8-to-istanbul": "^9.0.1",
    "vue": "^3.5.13",
    "vue-meta": "^3.0.0-alpha.10",
    "vue-router": "4.2.4"
  },
  "devDependencies": {
    "@babel/types": "^7.21.4",
    "@faker-js/faker": "^8.0.2",
    "@playwright/test": "^1.58.1",
    "@rushstack/eslint-patch": "^1.1.0",
    "@testing-library/vue": "^7.0.0",
    "@types/node": "^20.1.1",
    "@types/tabulator-tables": "^5.4.2",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitest/browser": "^0.33.0",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.36.0",
    "eslint-plugin-vue": "^9.6.0",
    "happy-dom": "^10.0.3",
    "jsdom": "^22.0.0",
    "naive-ui": "^2.29.0",
    "openapi-typescript-codegen": "^0.25.0",
    "playwright": "^1.32.2",
    "unplugin-vue-components": "^0.25.1",
    "vite": "^4.5.14",
    "vitest": "^0.33.0"
  }
}
